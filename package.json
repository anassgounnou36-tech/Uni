{
  "name": "uni",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "pnpm -r --filter \"@uni/*\" run typecheck",
    "test": "vitest run",
    "build": "pnpm -r --filter \"@uni/*\" run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.9"
  }
}
