{
  "name": "@uni/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/apps/bot/src/runtime/main.js",
    "start:shadow": "BOT_ENV_FILE=../../.env.shadow1 node dist/apps/bot/src/runtime/main.js",
    "replay": "node dist/apps/bot/src/replay/cli.js"
  },
  "dependencies": {
    "@uni/config": "workspace:*",
    "@uni/protocol": "workspace:*",
    "@uni/routing": "workspace:*",
    "@uni/sim": "workspace:*",
    "@uni/telemetry": "workspace:*",
    "dotenv": "^17.3.1",
    "pg": "^8.13.1",
    "viem": "^2.23.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11"
  }
}
